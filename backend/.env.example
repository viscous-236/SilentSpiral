# Copy this file to .env and fill in your values
# Never commit the actual .env to git

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false

# ── NLP ───────────────────────────────────────────────────────────────────────
NLP_MODEL_NAME=SamLowe/roberta-base-go_emotions
NLP_EMOTION_THRESHOLD=0.1
NLP_TOP_K=5

# ── HuggingFace Inference API (needed for Task 3 — Reflection Agent) ──────────
# Get your free token at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=your-huggingface-token-here

# ── Groq (free-tier LLM for reflection/session responses) ───────────────────
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas (recommended)
# Get this from Atlas dashboard -> Connect -> Drivers
# Example:
# mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URL=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=silent_spiral
MONGODB_USERS_COLLECTION=users

# Legacy Postgres fallback (optional during migration).
NEON_DATABASE_URL=
DATABASE_URL=

# ── Qdrant Cloud ──────────────────────────────────────────────────────────────
# Example URL: https://xxxx.us-east4-0.gcp.cloud.qdrant.io
QDRANT_URL=https://your-qdrant-cluster.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION_NAME=journal_entries
